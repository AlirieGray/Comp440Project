# Example environment variables for Comp440Project
# Option A: full DATABASE_URL (preferred)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# Option B: set MySQL components instead
MYSQL_USER=youruser
MYSQL_PASSWORD=yourpass
MYSQL_HOST=localhost
MYSQL_DB=comp440

# Optional: fallback SQLite path
SQLITE_PATH=sqlite:///app.db
